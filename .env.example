# Rename this file to .env and fill in your real keys
# Get these from: https://dashboard.razorpay.com -> Settings -> API Keys
# Use TEST keys first (start with rzp_test_), switch to LIVE keys (rzp_live_) when ready to go live

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret_here
